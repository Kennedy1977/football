{
  "name": "football",
  "version": "0.0.68",
  "description": "Football Manager Arcade MVP scaffold",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "npm run build",
    "notes:new": "node scripts/notes-new.mjs",
    "protocol:install": "node scripts/setup-git-protocol.mjs",
    "protocol:check:staged": "node scripts/protocol-check-staged.mjs",
    "protocol:check:commit-msg": "node scripts/protocol-check-commit-msg.mjs",
    "protocol:prepare": "npm run version:patch && npm run build:meta",
    "assets:card-frames": "node scripts/prepare-player-card-frames.mjs",
    "assets:card-portraits": "node scripts/prepare-player-card-portraits.mjs",
    "build:meta": "node scripts/generate-build-meta.mjs",
    "prebuild": "npm run build:meta",
    "prebuild:web": "npm run version:patch && npm run build:meta",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "start": "NODE_ENV=production node server.js",
    "dev": "tsx watch server.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "next build apps/web",
    "build:server": "tsc -p tsconfig.server.json",
    "web:dev": "next dev apps/web -p 3000",
    "api:start": "tsx apps/server/src/app.ts",
    "api:dev": "tsx watch apps/server/src/app.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/express": "^2.0.1",
    "@clerk/nextjs": "^7.0.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.19.0",
    "next": "^16.1.6",
    "phaser": "^3.90.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
