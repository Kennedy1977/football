{
  "name": "football",
  "version": "1.0.0",
  "description": "Football Manager Arcade MVP scaffold",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "tsx watch server.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "next build apps/web",
    "build:server": "tsc -p tsconfig.server.json",
    "web:dev": "next dev apps/web -p 3000",
    "api:start": "tsx apps/server/src/app.ts",
    "api:dev": "tsx watch apps/server/src/app.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mysql2": "^3.19.0",
    "next": "^16.1.6",
    "phaser": "^3.90.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
